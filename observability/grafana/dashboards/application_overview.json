{
  "id": null,
  "uid": "biorempp-app-overview",
  "title": "BioRemPP - Application Overview",
  "tags": [
    "biorempp",
    "application",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests/s (5m)",
      "id": 1,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(biorempp_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Error Ratio (5m)",
      "id": 2,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(biorempp_http_errors_total[5m])) / clamp_min(sum(rate(biorempp_http_requests_total[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Latency p95 (5m)",
      "id": 3,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(biorempp_http_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Workers Active",
      "id": 4,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "biorempp_workers_active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Throughput by Endpoint (req/s)",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(biorempp_http_requests_total[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Errors by HTTP Status",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(biorempp_http_errors_total[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Processing Duration p95 by Outcome",
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(biorempp_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Resume Outcomes (callback/load)",
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "biorempp-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(biorempp_resume_callback_attempts_total[5m]))",
          "legendFormat": "callback {{outcome}}",
          "refId": "A"
        },
        {
          "expr": "sum by (outcome) (rate(biorempp_resume_load_attempts_total[5m]))",
          "legendFormat": "load {{outcome}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    }
  ]
}
