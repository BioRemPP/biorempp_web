# ============================================================================
# BioRemPP v1.0.0 - Environment Variables Template
# ============================================================================
# Copy this file to create environment-specific configurations:
#   Development:  cp .env.example .env/.env.development
#   Production:   cp .env.example .env/.env.production
# 
# IMPORTANT: Never commit actual .env files to version control!
# ============================================================================

# ============================================================================
# PYTHON & BUILD
# ============================================================================
# Python version for Docker build
PYTHON_VERSION=3.11

# Application user (non-root for security)
APP_USER=biorempp
UID=1000
GID=1000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment type: development | production
BIOREMPP_ENV=development

# Server binding
BIOREMPP_HOST=0.0.0.0
BIOREMPP_PORT=8050

# Base URL path (set to / for root deployment, or /biorempp/ for subpath deployment)
BIOREMPP_URL_BASE_PATH=/

# Debug mode (MUST be False in production)
BIOREMPP_DEBUG=True

# Hot reload for development (MUST be False in production)
BIOREMPP_HOT_RELOAD=True

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
BIOREMPP_LOG_LEVEL=DEBUG

# ============================================================================
# GUNICORN (Production Only)
# ============================================================================
# Number of worker processes
# Formula: (2 x CPU_cores) + 1
BIOREMPP_WORKERS=4

# Worker class: sync | gevent | eventlet
BIOREMPP_WORKER_CLASS=gevent

# Max connections per worker (gevent/eventlet only)
BIOREMPP_WORKER_CONNECTIONS=1000

# Worker timeout (seconds)
BIOREMPP_TIMEOUT=300

# Keep-alive timeout (seconds)
BIOREMPP_KEEPALIVE=5

# Restart workers after N requests (prevents memory leaks)
BIOREMPP_MAX_REQUESTS=1000
BIOREMPP_MAX_REQUESTS_JITTER=100

# ============================================================================
# SECURITY
# ============================================================================
# Secret key for cryptographic operations
# PRODUCTION: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use default values in production!
SECRET_KEY=__SET_IN_PROD__

# ============================================================================
# CACHE (Redis - Optional; baseline runs without cache)
# ============================================================================
# Enable Redis caching
ENABLE_CACHE=False

# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=__SET_IN_PROD__

# Cache TTL (seconds)
CACHE_DEFAULT_TIMEOUT=300
CACHE_THRESHOLD=1000

# ============================================================================
# REVERSE PROXY / INSTITUTIONAL INGRESS
# ============================================================================
# Domain used by Nginx server_name. TLS is terminated upstream.
# Example: biorempp.example.com
DOMAIN=biorempp.institution.example

# ============================================================================
# NGINX
# ============================================================================
# Nginx configuration file
# Options: nginx.dev.conf | nginx.prod.conf
NGINX_CONFIG=nginx.prod.conf

# HTTP port (public ingress)
HTTP_PORT=80

# Optional local TLS mock profile (disabled by default)
# Profile: --profile nginx-mock
HTTP_MOCK_PORT_BIND=127.0.0.1:8081
HTTPS_MOCK_PORT_BIND=127.0.0.1:8443
TLS_MOCK_CERT_DAYS=365

# ============================================================================
# OBSERVABILITY (Prometheus + Grafana - Optional)
# ============================================================================
# Enable Prometheus instrumentation endpoint in the app
BIOREMPP_OBSERVABILITY_ENABLED=False
BIOREMPP_OBSERVABILITY_METRICS_PATH=/metrics
BIOREMPP_OBSERVABILITY_FAIL_FAST=False
BIOREMPP_TRUST_PROXY_HEADERS=False
# If set to True in production, BIOREMPP_TRUSTED_PROXY_CIDRS is mandatory
# and must contain institutional ingress/proxy CIDRs (non-loopback).
# Example institutional ingress/reverse-proxy CIDRs.
BIOREMPP_TRUSTED_PROXY_CIDRS=10.20.0.0/16,10.21.0.0/16
# Base path routed by ingress ("/" or "/biorempp/").
# Must match ingress route prefix exactly.
# BIOREMPP_URL_BASE_PATH=/biorempp/

# Operational contract example for TI:
# - Nginx/proxy body limit in current runtime: 32 MB
# - App parser limit: BIOREMPP_UPLOAD_MAX_SIZE_MB (default 5 MB)
# - Effective upload limit for users remains 5 MB unless app parser limit is increased
# - /metrics remains internal-only
BIOREMPP_PUBLIC_DATA_ALLOWED_FILES=exemple_dataset.txt
# Optional dedicated salt for log identifier redaction (HMAC).
# In production, prefer a dedicated secret; falls back to SECRET_KEY when omitted.
BIOREMPP_LOG_REF_SALT=__SET_IN_PROD__
# Length of redacted references in logs (8-24)
BIOREMPP_LOG_REF_LENGTH=12

# Distributed tracing correlation (header-based, no external tracer dependency)
# Nginx forwards traceparent/tracestate/X-B3-TraceId and app emits X-Trace-ID.
# Keep request correlation via X-Request-ID in all environments.

# Gunicorn/Prometheus multiprocess directory (use tmpfs in production)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
BIOREMPP_OBSERVABILITY_MULTIPROC_TMPFS_SIZE_BYTES=67108864

# Prometheus server retention and bind
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=5GB
PROMETHEUS_PORT_BIND=127.0.0.1:9090

# Alert thresholds (rendered at Prometheus startup from alerts.template.yml)
# Baseline (dev/staging) values:
BIOREMPP_HTTP_ERROR_RATIO_THRESHOLD=0.05
BIOREMPP_HTTP_P95_LATENCY_SECONDS_THRESHOLD=2
BIOREMPP_RESUME_ALERT_WINDOW=5m
BIOREMPP_RESUME_ALERT_NOT_FOUND_THRESHOLD=10
BIOREMPP_RESUME_ALERT_TOKEN_MISMATCH_THRESHOLD=5
BIOREMPP_RESUME_ALERT_SAVE_FAILED_THRESHOLD=2
BIOREMPP_RESUME_ALERT_RATE_LIMITED_THRESHOLD=20
BIOREMPP_RESUME_ALERT_RATE_LIMIT_ERROR_THRESHOLD=0
BIOREMPP_WORKERS_ACTIVE_MIN_THRESHOLD=2
BIOREMPP_WORKER_RESTART_RATE_THRESHOLD=0.1
BIOREMPP_CACHE_HIT_RATIO_MIN_THRESHOLD=0.2

# Grafana server and credentials
GRAFANA_PORT_BIND=127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__SET_IN_PROD__
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_ANALYTICS_REPORTING_ENABLED=false
GRAFANA_ANALYTICS_CHECK_FOR_UPDATES=false
GRAFANA_SERVER_ROOT_URL=http://localhost:3000

# ============================================================================
# JOB RESUME BASELINE
# ============================================================================
# Baseline (prod + nginx): no Redis dependency for resume.
BIOREMPP_RESUME_BACKEND=diskcache
BIOREMPP_RESUME_REDIS_HEALTHCHECK=false
BIOREMPP_RESUME_RATE_LIMIT_BACKEND=auto
BIOREMPP_RESUME_RATE_LIMIT_REDIS_KEY_PREFIX=biorempp:resume:ratelimit:
BIOREMPP_RESUME_SAVE_TIMEOUT_SECONDS=5.0

# Results payload transport (recommended for production)
BIOREMPP_RESULTS_PAYLOAD_MODE=server
BIOREMPP_RESULTS_HYDRATION_CACHE_SIZE=64
BIOREMPP_RESULTS_HYDRATION_CACHE_TTL_SECONDS=900
BIOREMPP_RESULTS_HYDRATION_RETRY_ATTEMPTS=8
BIOREMPP_RESULTS_HYDRATION_RETRY_DELAY_MS=250

# Optional full-stack overlay (gitignored):
#   .env/env.production.stack
# Run full stack:
#   docker compose --env-file .env/env.production --env-file .env/env.production.stack \
#     --profile prod --profile cache --profile observability up -d

# ============================================================================
# DOCKER PORTS
# ============================================================================
# Host ports for accessing services
DEV_PORT=8050
PROD_PORT=8080

# ============================================================================
# DATABASE (Future - Currently not used)
# ============================================================================
# Uncomment when database is implemented
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=biorempp
# DB_USER=biorempp
# DB_PASSWORD=change-me-in-production

# ============================================================================
# MONITORING & LOGGING (Future)
# ============================================================================
# Uncomment when monitoring is implemented
# SENTRY_DSN=
# LOG_FORMAT=json
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5

# ============================================================================
# PERFORMANCE
# ============================================================================
# Enable profiling (development only)
ENABLE_PROFILING=False

# Enable compression
ENABLE_COMPRESSION=True

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================
# Enable Dash dev tools
DASH_DEBUG=True

# Enable Dash UI components
DASH_UI_COMPONENTS=True
